{
  "name": "iofund-agent-chat",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "predev": "scripts/copy-data.sh",
    "dev": "next dev --turbopack",
    "prebuild": "scripts/copy-data.sh",
    "build": "next build",
    "start": "next start",
    "type-check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "preeval": "scripts/copy-data.sh",
    "eval": "tsx --env-file=.env.local evals/run.ts",
    "test": "scripts/run-tests.sh",
    "test:verbose": "TEST_VERBOSE=1 scripts/run-tests.sh",
    "test:articles": "tsx --env-file=.env.local evals/articles-api.test.ts",
    "test:threads": "tsx --env-file=.env.local evals/threads.test.ts",
    "test:page-context": "tsx evals/page-context.test.ts",
    "test:gap": "tsx evals/gap.test.ts",
    "test:webhook": "tsx evals/neon-webhook.test.ts"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.186",
    "@neondatabase/auth": "0.4.1-beta",
    "@neondatabase/auth-ui": "0.2.0-beta",
    "@neondatabase/serverless": "^1.1.0",
    "ai": "^6.0.184",
    "drizzle-orm": "^0.45.2",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "typescript": "^5.7.0"
  }
}
